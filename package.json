{
  "name": "synthreel",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "SynthReel — retro cassette deck music player powered by Strudel live coding",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:e2e": "playwright test --project=chromium",
    "typecheck": "tsc --noEmit",
    "demo:gif": "node scripts/generate-demo-gif.mjs",
    "qa:matrix": "playwright test --workers=1 --project=chromium --project=firefox --project=webkit --project=\"mobile-chrome\" --project=\"mobile-chrome-375\" --project=\"mobile-chrome-360\" --project=\"mobile-safari-se\"",
    "preview": "vite preview",
    "generate-rj": "node scripts/generate-rj.mjs",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "gifenc": "^1.0.3",
    "globals": "^16.5.0",
    "jsdom": "^25.0.1",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "AGPL-3.0-or-later"
}
